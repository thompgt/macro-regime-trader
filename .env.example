# Copy to .env and adjust as needed. No API key required for the default yfinance provider.

MRT_DATA_CACHE_DIR=data_cache
MRT_LOG_LEVEL=INFO

# Risk manager limits
MRT_STARTING_BALANCE=100000
MRT_SLIPPAGE_PCT=0.0004
MRT_CIRCUIT_BREAKER_DRAWDOWN_PCT=0.025
MRT_CIRCUIT_BREAKER_HALT_STEPS=48
MRT_KILL_SWITCH_DRAWDOWN_PCT=0.12

# Regime engine
MRT_EMA_FAST=20
MRT_EMA_SLOW=50
MRT_VOLUME_ZSCORE_WINDOW=20

# Backtest
MRT_TRAIN_WINDOW=180
MRT_TEST_WINDOW=60
